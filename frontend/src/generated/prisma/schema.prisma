generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name     String
  last_name      String
  email          String               @unique
  external_id    String
  created_at     DateTime             @default(now()) @db.Timestamp(6)
  updated_at     DateTime             @default(now()) @db.Timestamp(6)
  transactions   transactions[]
  assigned_roles user_roles_mapping[] @relation("AssignedBy")
  user_roles     user_roles_mapping[]
}

model roles {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String               @unique(map: "roles_name_unique")
  description String?
  is_active   Boolean              @default(true)
  created_at  DateTime             @default(now()) @db.Timestamp(6)
  updated_at  DateTime             @default(now()) @db.Timestamp(6)
  user_roles  user_roles_mapping[]
}

model user_roles_mapping {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  role_id          String    @db.Uuid
  assigned_by      String?   @db.Uuid
  is_active        Boolean   @default(true)
  expires_at       DateTime? @db.Timestamp(6)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  updated_at       DateTime  @default(now()) @db.Timestamp(6)
  assigned_by_user users?    @relation("AssignedBy", fields: [assigned_by], references: [id], onUpdate: NoAction, map: "fk_user_roles_assigned_by")
  role             roles     @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_roles_role")
  user             users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_roles_user")

  @@unique([user_id, role_id], name: "user_role_unique", map: "user_role_unique")
}

model mandals {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label_english String
  created_at    DateTime   @default(now()) @db.Timestamp(6)
  updated_at    DateTime   @default(now()) @db.Timestamp(6)
  villages      villages[]
}

model members {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  given_name              String
  family_name             String
  village_id              String                    @db.Uuid
  house_number            String
  phone_number            String                    @unique(map: "members_phone_number_unique")
  husband_or_father_name  String
  aadhar_number           String                    @unique(map: "members_aadhar_number_unique")
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  updated_at              DateTime                  @default(now()) @db.Timestamp(6)
  name_labels             member_name_labels[]
  villages                villages                  @relation(fields: [village_id], references: [id], onUpdate: NoAction, map: "fk_members_village")
  members_accounts_onlink members_accounts_onlink[]
  transactions            transactions[]
}

model member_name_labels {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id     String   @db.Uuid
  language_code String   @db.VarChar(10)
  given_name    String
  family_name   String
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @db.Timestamp(6)
  member        members  @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_member_name_labels_member")

  @@unique([member_id, language_code], name: "member_name_labels_unique", map: "member_name_labels_unique")
}

model transactions {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supervisor_id    String            @db.Uuid
  member_id        String            @db.Uuid
  transaction_type credit_debit_type
  account_id       String            @db.Uuid
  amount           Int
  comments         String?
  transaction_date DateTime          @db.Date
  receipt_number   String            @db.VarChar(255)
  is_archived      Boolean           @default(false)
  created_at       DateTime          @default(now()) @db.Timestamp(6)
  updated_at       DateTime          @default(now()) @db.Timestamp(6)
  accounts         accounts          @relation(fields: [account_id], references: [id], onUpdate: NoAction, map: "fk_transactions_account")
  members          members           @relation(fields: [member_id], references: [id], onUpdate: NoAction, map: "fk_transactions_member")
  users            users             @relation(fields: [supervisor_id], references: [id], onUpdate: NoAction, map: "fk_transactions_user")
}

model villages {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label_english String
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @default(now()) @db.Timestamp(6)
  mandal_id     String    @db.Uuid
  members       members[]
  mandals       mandals   @relation(fields: [mandal_id], references: [id], onUpdate: NoAction, map: "fk_villages_mandal")
}

model endpointaccess {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role        String   @db.VarChar(255)
  endpoint    String   @db.VarChar(255)
  viewer      Boolean
  contributor Boolean
  admin       Boolean
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)

  @@unique([role, endpoint], map: "role_endpoint_unique")
}

model account_types {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String     @unique(map: "account_types_name_unique") @db.VarChar(255)
  label_english String     @db.VarChar(255)
  description   String?
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now()) @db.Timestamp(6)
  updated_at    DateTime   @default(now()) @db.Timestamp(6)
  accounts      accounts[]
}

model accounts {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String                    @db.VarChar(255)
  account_number          String                    @db.VarChar(255)
  balance                 Int                       @default(0)
  account_type_id         String                    @db.Uuid
  description             String?
  is_active               Boolean                   @default(true)
  created_at              DateTime                  @default(now()) @db.Timestamp(6)
  updated_at              DateTime                  @default(now()) @db.Timestamp(6)
  account_types           account_types             @relation(fields: [account_type_id], references: [id], onUpdate: NoAction, map: "fk_accounts_account_type")
  members_accounts_onlink members_accounts_onlink[]
  transactions            transactions[]
}

model i18n_labels {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_table  String   @db.VarChar(255)
  entity_id     String   @db.Uuid
  field         String   @db.VarChar(255)
  language_code String   @db.VarChar(10)
  text          String
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @db.Timestamp(6)

  @@unique([entity_table, entity_id, field, language_code], map: "i18n_entity_field_lang_unique")
}

model members_accounts_onlink {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id  String   @db.Uuid
  account_id String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  accounts   accounts @relation(fields: [account_id], references: [id], onUpdate: NoAction, map: "fk_member_account_account")
  members    members  @relation(fields: [member_id], references: [id], onUpdate: NoAction, map: "fk_member_account_member")

  @@unique([member_id, account_id], map: "member_account_unique")
}

enum credit_debit_type {
  credit
  debit
}
